<main class="main-content main-content--dashboard">
  <div class="c-toolbar">
    <div class="c-toolbar__row items-center w-full gap-3">
      <%= link_to "Back to release dates", admin_course_grade_release_dates_path, class: tailwind_button_classes(:secondary) %>
    </div>
  </div>

  <div class="c-container c-container--wide c-page">
    <section class="u-stack u-stack--lg">
      <header class="c-card p-6 md:p-8 bg-slate-50 border border-slate-200">
        <div>
          <h1 class="text-2xl font-semibold text-slate-900">Set Release Date</h1>
          <p class="mt-2 text-sm text-slate-600">
            Configure when <strong><%= @semester.name %></strong> course competency results become visible.
          </p>
        </div>
      </header>

      <div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
        <section class="c-card p-6 md:p-8">
          <%= form_with model: @release_date, url: admin_course_grade_release_dates_path, method: :post, local: true, class: "u-stack u-stack--md" do |f| %>
            <input type="hidden" name="course_grade_release_date[program_semester_id]" value="<%= @semester.id %>" />

            <div class="c-field">
              <%= f.label :release_date, "Release Date & Time", class: "c-label" %>
              <%= f.datetime_local_field :release_date, 
                    class: "c-input",
                    placeholder: "Leave blank to make visible by default" %>
              <small class="c-help">Leave blank to make results visible immediately (default behavior).</small>
            </div>

            <div class="border-t pt-4">
              <p class="text-sm text-slate-700 mb-3"><strong>Preview:</strong></p>
              <p class="text-sm">
                Results will be <span class="font-semibold text-green-700">visible immediately (no embargo)</span>
              </p>
            </div>

            <div class="c-form-actions u-actions u-actions--start">
              <%= f.submit "Create", class: tailwind_button_classes(:primary) %>
            </div>
          <% end %>
        </section>

        <aside class="u-stack u-stack--sm">
          <div class="c-card bg-slate-50 border border-slate-200 p-4">
            <p class="text-sm font-semibold text-slate-900 mb-2">Semester Details</p>
            <dl class="space-y-2 text-xs text-slate-700">
              <div>
                <dt class="font-medium">Name</dt>
                <dd><%= @semester.name %></dd>
              </div>
              <div>
                <dt class="font-medium">Current semester</dt>
                <dd><%= @semester.is_current? ? "Yes" : "No" %></dd>
              </div>
            </dl>
          </div>

          <div class="c-card bg-blue-50 border border-blue-200 p-4">
            <p class="text-xs text-blue-900">
              <strong>Note:</strong> This release date applies to all surveys in this semester. Students cannot see course-derived competency results until the date passes.
            </p>
          </div>
        </aside>
      </div>
    </section>
  </div>
</main>
