<main class="main-content space-y-10">
  <div class="c-toolbar c-toolbar--spaced">
    <div class="c-toolbar__row justify-between w-full">
      <%= link_to "Back to Admin Dashboard", admin_dashboard_path, class: tailwind_button_classes(:secondary) %>
    </div>
  </div>

  <header class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div class="space-y-2">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Recent Activities</h1>
      <p class="max-w-3xl text-sm text-slate-600">A single timeline for survey change logs, student submissions, and advisor feedback activity.</p>
    </div>
  </header>

  <section class="c-card c-card--flush">
    <div class="c-panel-header c-panel-header--with-border">
      <div class="c-callout">
        <%= form_with url: admin_activities_path, method: :get, local: true, class: "c-toolbar__row c-toolbar__row--airy w-full md:flex-nowrap" do %>
          <div class="c-toolbar__item relative flex-1">
            <%= text_field_tag :q, @search_query, placeholder: "Search logs by survey, student, actor, or action", class: "c-input c-search-input w-full pr-16" %>
          </div>
          <div class="c-toolbar__item flex items-center gap-2">
            <%= submit_tag "Search", class: tailwind_button_classes(:secondary) %>
            <% if @search_query.present? %>
              <%= link_to "Reset", admin_activities_path, class: tailwind_button_classes(:subtle) %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <% if @entries.blank? %>
      <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center text-sm text-slate-600">
        <%= @search_query.present? ? "No logs matched your search." : "No activity logs yet." %>
      </div>
    <% else %>
      <div class="c-table-wrapper">
        <table class="c-table min-w-full w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th scope="col" class="whitespace-nowrap px-4 py-3 text-left font-semibold">Timestamp</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 text-left font-semibold">Type</th>
              <th scope="col" class="px-4 py-3 text-left font-semibold">Activity</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 text-left font-semibold">User</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-slate-600">
            <% @entries.each do |entry| %>
              <tr class="hover:bg-slate-50">
                <td class="whitespace-nowrap px-4 py-3 align-top text-slate-500">
                  <%= l(entry[:timestamp], format: :long) %>
                </td>
                <td class="whitespace-nowrap px-4 py-3 align-top">
                  <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-700">
                    <%= entry[:type] %>
                  </span>
                </td>
                <td class="px-4 py-3 align-top">
                  <p class="font-semibold text-slate-900">
                    <% if entry[:link].present? %>
                      <%= link_to entry[:title], entry[:link], class: "text-indigo-700 hover:text-indigo-800" %>
                    <% else %>
                      <%= entry[:title] %>
                    <% end %>
                  </p>
                  <% if entry[:subtitle].present? %>
                    <p class="mt-1 text-xs text-slate-500"><%= entry[:subtitle] %></p>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-4 py-3 align-top text-slate-700"><%= entry[:actor] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>
</main>
