<!-- Main Content for Admin Dashboard - layout provides html/head/body and navbar -->
<main class="main-content main-content--dashboard">
  <%= render "shared/role_switcher" %>

  <section class="c-card c-card--hover p-8 md:p-10">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <h1 class="c-section-title c-heading-inline">Admin Dashboard</h1>
      <p class="mt-1 text-sm leading-relaxed text-slate-600">System management for the MHA Program</p>
    </div>
    
    <div class="dashboard-grid dashboard-grid-4">
      <!-- Surveys -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to admin_surveys_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">📄</div>
          <div class="c-tile__title">Survey Builder</div>
          <div class="c-tile__description">Create & manage surveys</div>
        <% end %>
      </div>

      <!-- Survey Assignment -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to assignments_surveys_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">🧾</div>
          <div class="c-tile__title">Assign Surveys</div>
          <div class="c-tile__description">Assign/unassign surveys to students</div>
        <% end %>
      </div>

      <!-- Program Configuration -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to admin_program_setup_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">🧩</div>
          <div class="c-tile__title">Program Configuration</div>
          <div class="c-tile__description">Tracks, majors, semesters, and competency targets</div>
        <% end %>
      </div>

      <!-- Reports -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to reports_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">📊</div>
          <div class="c-tile__title">Reports</div>
          <div class="c-tile__description"><%= @total_reports || 0 %> generated</div>
        <% end %>
      </div>

      <!-- Portfolio Export -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to student_portfolio_export_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">🔗</div>
          <div class="c-tile__title">Portfolio Export</div>
          <div class="c-tile__description">Export student Google Sites portfolio URLs</div>
        <% end %>
      </div>

      <!-- Competencies -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to admin_competencies_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">🧠</div>
          <div class="c-tile__title">Competencies</div>
          <div class="c-tile__description">Compare self, advisor, and course ratings</div>
        <% end %>
      </div>

      <!-- Students Records -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to student_records_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">👨‍🎓</div>
          <div class="c-tile__title">Students Records</div>
          <div class="c-tile__description"><%= @role_counts[:student] || 0 %> registered</div>
        <% end %>
      </div>

      <!-- People Management -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to people_management_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">🧑‍🤝‍🧑</div>
          <div class="c-tile__title">People Management</div>
          <div class="c-tile__description">Members, students, advisors, and assignments</div>
        <% end %>
      </div>

      <!-- Recent Activities -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to admin_activities_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">📚</div>
          <div class="c-tile__title">Recent Activities</div>
          <div class="c-tile__description">Survey and submission logs</div>
        <% end %>
      </div>

      <!-- Grade Imports -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to admin_grade_import_batches_path, class: "c-tile__link" do %>
          <div class="c-tile__icon">📥</div>
          <div class="c-tile__title">Grade Imports</div>
          <div class="c-tile__description">Upload faculty workbooks</div>
        <% end %>
      </div>

      <!-- View as Student/Advisor -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to new_impersonation_path, class: "c-tile__link" do %>
          <div class="c-tile__icon c-tile__icon--warning">🕵️</div>
          <div class="c-tile__title c-tile__title--warning">View as Student/Advisor</div>
          <div class="c-tile__description">Read-only preview</div>
        <% end %>
      </div>

      <!-- Maintenance Mode -->
      <div class="c-card c-card--interactive c-card--hover c-card--lift c-tile">
        <%= link_to admin_maintenance_path, class: "c-tile__link" do %>
          <div class="c-tile__icon c-tile__icon--warning">🛠️</div>
          <div class="c-tile__title c-tile__title--warning">Maintenance Mode</div>
          <div class="c-tile__description"><%= @maintenance_enabled ? "Enabled" : "Disabled" %></div>
        <% end %>
      </div>
    </div>
  </section>
</main>
