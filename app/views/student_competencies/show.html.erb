<% selected_semester = @payload.dig(:filters, :semester).presence || "All semesters" %>
<% show_advisor = @payload[:show_advisor] %>

<main class="main-content c-page">
  <header class="c-card c-page-header">
    <div class="u-stack u-stack--sm">
      <span class="c-eyebrow"><%= selected_semester %></span>
      <h1 class="c-page-title">My Competencies</h1>
      <p class="c-page-subtitle"><%= show_advisor ? "Self, advisor, course, and target levels in one semester view." : "Self, course, and target levels in one semester view." %></p>
    </div>

    <%= link_to "Export CSV",
          student_competencies_path(format: :csv, semester: @payload.dig(:filters, :semester)),
          class: tailwind_button_classes(:secondary),
          data: { turbo: false } %>
  </header>

  <section class="c-card c-card--tight">
    <%= form_with url: student_competencies_path, method: :get, local: true, data: { turbo: false }, class: "c-filter-bar" do %>
      <div class="c-filter-bar__field">
        <label class="c-label" for="semester">Semester</label>
        <%= select_tag :semester,
              options_for_select(@payload[:semesters], @payload.dig(:filters, :semester)),
              class: "c-select" %>
      </div>
      <%= submit_tag "Apply", class: tailwind_button_classes(:primary) %>
      <span class="c-status-pill <%= @payload[:course_released] ? 'c-status-pill--success' : 'c-status-pill--warning' %>">
        Course results: <%= @payload[:release_label] %>
      </span>
    <% end %>
  </section>

  <section class="c-card c-card--tight">
    <div class="c-panel-header">
      <h2 class="c-section-title c-heading-inline">Graphs</h2>
      <div class="c-tabs" role="tablist" aria-label="Competency graph views">
        <button type="button" class="c-tab is-active" id="competencySnapshotTab" role="tab" aria-selected="true" aria-controls="competencySnapshotPanel" data-competency-chart-tab="snapshot">
          Competency Snapshot
        </button>
        <button type="button" class="c-tab" id="semesterTrendTab" role="tab" aria-selected="false" aria-controls="semesterTrendPanel" data-competency-chart-tab="trend">
          Semester Trend
        </button>
      </div>
    </div>

    <div class="c-chart-panels">
      <div class="c-chart-panel is-active" id="competencySnapshotPanel" role="tabpanel" aria-labelledby="competencySnapshotTab" data-competency-chart-panel="snapshot">
        <div class="c-chart-frame c-chart-frame--lg">
          <canvas id="competencyRadarChart"></canvas>
        </div>
      </div>

      <div class="c-chart-panel" id="semesterTrendPanel" role="tabpanel" aria-labelledby="semesterTrendTab" data-competency-chart-panel="trend" hidden>
        <div class="c-chart-frame c-chart-frame--lg">
          <canvas id="competencyTrendChart"></canvas>
        </div>
      </div>
    </div>
  </section>

  <section class="u-stack u-stack--lg">
    <% @payload[:domains].each do |domain| %>
      <section class="c-card c-card--flush c-section-group">
        <header class="c-section-group__header">
          <h2><%= domain[:name] %></h2>
          <span><%= pluralize(domain[:competencies].size, "competency") %></span>
        </header>

        <div class="c-table-wrapper">
          <table class="c-table c-matrix-table">
            <thead>
              <tr>
                <th>Competency</th>
                <th>Self</th>
                <% if show_advisor %>
                  <th>Advisor</th>
                <% end %>
                <th>Course</th>
                <th>End of Program Target</th>
              </tr>
            </thead>
            <tbody>
              <% domain[:competencies].each do |competency| %>
                <tr>
                  <td class="c-table__title"><%= competency[:title] %></td>
                  <td>
                    <span class="c-score-pill c-score-pill--self <%= 'c-score-pill--empty' if competency[:self_rating].blank? %>">
                      <%= competency[:self_rating].presence || "—" %>
                    </span>
                  </td>
                  <% if show_advisor %>
                    <td>
                      <span class="c-score-pill c-score-pill--advisor <%= 'c-score-pill--empty' if competency[:advisor_rating].blank? %>">
                        <%= competency[:advisor_rating].presence || "—" %>
                      </span>
                    </td>
                  <% end %>
                  <td>
                    <% course_value = @payload[:course_released] ? competency[:course_rating].presence : "Embargoed" %>
                    <% if !@payload[:course_released] %>
                      <span class="c-score-pill c-score-pill--empty">Embargoed</span>
                    <% elsif competency[:course_sources].present? %>
                      <details class="c-cell-details">
                        <summary class="c-cell-details__summary">
                          <span class="c-score-pill c-score-pill--course <%= 'c-score-pill--empty' if course_value.blank? %>">
                            <%= course_value.presence || "—" %>
                          </span>
                        </summary>
                        <div class="c-source-list">
                          <span class="c-source-count"><%= pluralize(competency[:course_sources].size, "source") %></span>
                          <% competency[:course_sources].each do |source| %>
                            <div class="c-source-chip">
                              <strong><%= source[:course_code] %></strong>
                              <span>Competency level <%= source[:mapped_level].presence || "—" %></span>
                              <span>Target level <%= source[:course_target_level].presence || "—" %></span>
                            </div>
                          <% end %>
                        </div>
                      </details>
                    <% else %>
                      <span class="c-score-pill c-score-pill--empty">—</span>
                    <% end %>
                  </td>
                  <td>
                    <span class="c-score-pill c-score-pill--program <%= 'c-score-pill--empty' if competency[:end_program_target].blank? %>">
                      <%= competency[:end_program_target].presence || "—" %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>
  </section>
</main>

<script type="module">
  import Chart from "chart.js/auto"

  const radarPayload = <%= raw @payload[:radar_chart].to_json %>
  const trendPayload = <%= raw @payload[:trend_chart].to_json %>
  const colors = {
    Self: ["rgba(80, 0, 0, 0.18)", "#500000"],
    Advisor: ["rgba(37, 99, 235, 0.16)", "#2563eb"],
    Course: ["rgba(5, 150, 105, 0.16)", "#059669"],
    "End Program Target": ["rgba(124, 58, 237, 0.1)", "#7c3aed"]
  }

  const decorate = (dataset) => {
    const [backgroundColor, borderColor] = colors[dataset.label] || ["rgba(15, 23, 42, 0.1)", "#0f172a"]
    return { ...dataset, backgroundColor, borderColor, borderWidth: 2, pointRadius: 2, spanGaps: true }
  }

  const radarChart = new Chart(document.getElementById("competencyRadarChart"), {
    type: "radar",
    data: { labels: radarPayload.labels, datasets: radarPayload.datasets.map(decorate) },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: { r: { min: 0, max: 5, ticks: { stepSize: 1 } } },
      plugins: { legend: { position: "bottom" } }
    }
  })

  const trendChart = new Chart(document.getElementById("competencyTrendChart"), {
    type: "line",
    data: { labels: trendPayload.labels, datasets: trendPayload.datasets.map(decorate) },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: { y: { min: 0, max: 5, ticks: { stepSize: 1 } } },
      plugins: { legend: { position: "bottom" } }
    }
  })

  const charts = { snapshot: radarChart, trend: trendChart }
  const tabs = document.querySelectorAll("[data-competency-chart-tab]")
  const panels = document.querySelectorAll("[data-competency-chart-panel]")

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const activeView = tab.dataset.competencyChartTab

      tabs.forEach((candidate) => {
        const selected = candidate.dataset.competencyChartTab === activeView
        candidate.classList.toggle("is-active", selected)
        candidate.setAttribute("aria-selected", selected ? "true" : "false")
      })

      panels.forEach((panel) => {
        const selected = panel.dataset.competencyChartPanel === activeView
        panel.classList.toggle("is-active", selected)
        panel.hidden = !selected
      })

      window.requestAnimationFrame(() => charts[activeView]?.resize())
    })
  })
</script>
