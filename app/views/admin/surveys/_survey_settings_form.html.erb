<section class="c-card space-y-6">
  <header class="flex flex-wrap items-start justify-between gap-4 border-b border-slate-200 pb-4">
    <div class="space-y-1">
      <h2 class="text-lg font-semibold text-slate-900">Survey metadata</h2>
      <p class="text-sm text-slate-600">Configure survey identity, availability, and track assignment.</p>
    </div>

    <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
      <label class="c-toggle cursor-pointer">
        <%= form.check_box :is_active, class: "c-toggle__input" %>
        <span class="c-toggle__track" aria-hidden="true"><span class="c-toggle__thumb"></span></span>
        <span class="space-y-0.5">
          <span class="c-toggle__label block">Survey is active</span>
          <span class="block text-xs text-slate-500">Inactive surveys stay hidden from advisors.</span>
        </span>
      </label>
    </div>
  </header>

  <div class="grid gap-6 md:grid-cols-2">
    <div class="c-field md:col-span-2">
      <%= form.label :title, "Survey title", class: "c-label" %>
      <%= form.text_field :title,
                          required: true,
                          class: "#{input_classes} c-input w-full",
                          placeholder: "Capstone Competency Survey" %>
    </div>

    <div class="c-field">
      <%= form.label :semester, "Semester", class: "c-label" %>
      <% if @program_semester_options.present? %>
        <div class="c-select-wrapper max-w-md">
          <%= form.select :semester,
                          options_for_select(@program_semester_options, survey.semester.presence || @program_semester_options.first),
                          { include_blank: "Select semester" },
                          class: "c-select" %>
        </div>
      <% else %>
        <%= form.text_field :semester,
                            required: true,
                            class: "#{input_classes} c-input max-w-md",
                            placeholder: "Fall 2025" %>
      <% end %>
    </div>

    <div class="c-field">
      <label for="survey-track-list" class="c-label">Track assignment</label>
      <%= hidden_field_tag "survey[track_list][]", "" %>
      <% track_dropdown_options = [["Select a track", ""]] + track_options.map { |track| [track, track] } %>
      <div class="c-select-wrapper max-w-md">
        <%= select_tag "survey[track_list][]",
                       options_for_select(track_dropdown_options, survey.track_list.first),
                       id: "survey-track-list",
                       class: "c-select" %>
      </div>
    </div>

    <div class="c-field">
      <%= form.label :available_from, "Available from", class: "c-label" %>
      <%= form.datetime_local_field :available_from, class: "#{input_classes} c-input max-w-md" %>
    </div>

    <div class="c-field">
      <%= form.label :available_until, "Available until", class: "c-label" %>
      <%= form.datetime_local_field :available_until, class: "#{input_classes} c-input max-w-md" %>
    </div>

    <div class="c-field md:col-span-2">
      <%= form.label :description, "Summary", class: "c-label" %>
      <%= form.text_area :description, class: textarea_classes, placeholder: "Explain where this survey fits in the advising process." %>
    </div>
  </div>
</section>

<% if SurveyOffering.data_source_ready? && survey.persisted? && survey.offerings.any? %>
  <section class="c-card space-y-6">
    <header class="space-y-1 border-b border-slate-200 pb-4">
      <h2 class="text-lg font-semibold text-slate-900">Review meeting dates</h2>
      <p class="text-sm text-slate-600">Edit the review meeting window shown to students (per offering).</p>
    </header>

    <div class="c-table-wrapper">
      <table class="c-table c-table--sm c-table--divide">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-5 py-3 text-left font-semibold text-slate-700">Track</th>
            <th class="px-5 py-3 text-left font-semibold text-slate-700">Class of</th>
            <th class="px-5 py-3 text-left font-semibold text-slate-700">Stage</th>
            <th class="px-5 py-3 text-left font-semibold text-slate-700">Review start</th>
            <th class="px-5 py-3 text-left font-semibold text-slate-700">Review end</th>
          </tr>
        </thead>
        <tbody class="bg-white">
          <% sorted_offerings = survey.offerings.sort_by { |row| [row.track.to_s, row.class_of.to_i, row.stage.to_s] } %>
          <%= form.fields_for :offerings, sorted_offerings do |offering_fields| %>
            <% offering = offering_fields.object %>
            <tr>
              <td class="px-5 py-4 text-slate-800"><%= offering.track %></td>
              <td class="px-5 py-4 text-slate-800"><%= offering.class_of.presence || "All" %></td>
              <td class="px-5 py-4 text-slate-800"><%= offering.stage.to_s.titleize %></td>
              <td class="px-5 py-4">
                <%= offering_fields.hidden_field :id %>
                <%= offering_fields.date_field :review_meetings_start, class: "#{input_classes} c-input max-w-[11rem] text-sm px-2 py-1.5" %>
              </td>
              <td class="px-5 py-4">
                <%= offering_fields.date_field :review_meetings_end, class: "#{input_classes} c-input max-w-[11rem] text-sm px-2 py-1.5" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

