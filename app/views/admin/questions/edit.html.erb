<main class="main-content main-content--dashboard">
  <div class="c-toolbar">
    <div class="c-toolbar__row items-center w-full gap-3">
      <%= link_to "Back to Question Bank", admin_questions_path, class: tailwind_button_classes(:secondary) %>
    </div>
  </div>

  <div class="c-container c-container--dashboard c-page">
    <section class="c-card p-8 md:p-10 u-stack u-stack--lg">
      <header class="c-page-header">
        <div>
          <p class="c-eyebrow">Survey admin</p>
          <h1 class="c-page-title">Edit Question</h1>
          <p class="c-page-subtitle">Update the prompt content, order, and tags.</p>
        </div>
      </header>

      <%= render "form", question: @question %>
    </section>
  </div>
</main>
