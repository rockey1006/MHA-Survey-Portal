<main class="main-content main-content--dashboard">
  <div class="c-toolbar">
    <div class="c-toolbar__row items-center w-full gap-3">
      <%= link_to "Back to Surveys", admin_surveys_path, class: tailwind_button_classes(:secondary) %>
    </div>
  </div>

  <div class="c-container c-container--dashboard c-page">
    <section class="c-card p-8 md:p-10 u-stack u-stack--xl">
      <header class="c-page-header">
        <div>
          <p class="c-eyebrow">Survey admin</p>
          <h1 class="c-page-title">Question Bank</h1>
          <p class="c-page-subtitle">Create, edit, and remove prompts that can be assigned to surveys.</p>
        </div>
        <%= link_to "New Question", new_admin_question_path, class: tailwind_button_classes(:primary) %>
      </header>

    <section class="u-stack u-stack--md">
      <div>
        <h2 class="c-section-title c-heading-inline">Questions</h2>
        <p class="text-sm text-slate-600">Manage reusable prompts, question types, and their survey assignments from one place.</p>
      </div>

    <div class="c-card c-card--flush">
      <% if @questions.blank? %>
        <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center text-sm text-slate-600">No questions have been created yet.</div>
      <% else %>
        <div class="c-table-wrapper">
          <table class="c-table survey-table">
            <thead>
              <tr>
                <th>Order</th>
                <th>Question</th>
                <th>Type</th>
                <th>Categories</th>
                <th>Surveys</th>
                <th class="actions-column">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @questions.each do |question| %>
                <tr class="survey-table-row">
                  <td class="survey-meta-cell"><%= question.question_order %></td>
                  <td class="survey-title"><%= question.question %></td>
                  <td class="survey-meta-cell"><%= question.question_type.humanize %></td>
                  <% category = question.category %>
                  <% survey = category&.survey %>
                  <td class="survey-meta-cell">
                    <% if category.present? %>
                      <span class="meta-chip"><%= category.name %></span>
                    <% else %>
                      <span class="meta-chip">Unassigned</span>
                    <% end %>
                  </td>
                  <td class="survey-meta-cell">
                    <% if survey.present? %>
                      <span class="meta-chip"><%= survey.title %></span>
                    <% else %>
                      <span class="meta-chip">Unassigned</span>
                    <% end %>
                  </td>
                  <td class="survey-table-actions">
                    <%= link_to "Edit", edit_admin_question_path(question), class: tailwind_button_classes(:secondary) %>
                    <%= link_to "Delete", admin_question_path(question),
                      data: { turbo_method: :delete, turbo_confirm: "Delete this question? It will be removed from any surveys it's assigned to." },
                      class: tailwind_button_classes(:danger) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
    </section>
    </section>
  </div>
</main>
