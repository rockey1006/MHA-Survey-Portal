<% input_classes = "c-input" %>

<section class="c-card space-y-6"
         data-controller="markdown-editor">
  <header class="space-y-1">
    <h2 class="text-lg font-semibold text-slate-900">Rating scale legend</h2>
    <p class="text-sm text-slate-600">Edit the long-form legend content and preview how it will appear in the survey.</p>
  </header>

  <div class="w-full">
    <div class="w-full">
      <div class="c-card c-card--tight space-y-5 border border-slate-200">
      <%= form.fields_for :legend, (survey.legend || survey.build_legend(title: "", body: "")) do |legend_fields| %>
        <div class="c-field">
          <%= legend_fields.label :title, "Legend title", class: "c-label" %>
          <%= legend_fields.text_field :title,
                                       class: "#{input_classes}",
                                       placeholder: "Rating Scale Reference" %>
        </div>

        <div class="c-field">
          <div class="flex items-center justify-between gap-3">
            <%= legend_fields.label :body, "Legend body", class: "c-label" %>
            <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">Markdown supported</span>
          </div>
          <%= legend_fields.text_area :body,
                                       class: "#{input_classes} min-h-[500px] font-mono leading-6",
                                       rows: 18,
                                       placeholder: "Add the full rating scale text shown to students." %>
          <p class="text-xs text-slate-500">Supports real Markdown. Shortcuts: Ctrl/Cmd+B bold, Ctrl/Cmd+I italic, Ctrl/Cmd+K link.</p>
        </div>
      <% end %>
      </div>
    </div>
  </div>
</section>
