<main class="main-content main-content--dashboard">
  <div class="c-toolbar">
    <div class="c-toolbar__row items-center w-full gap-3">
      <%= link_to "Back", dashboard_path, class: tailwind_button_classes(:secondary) %>
    </div>
  </div>

  <div class="c-container c-container--wide c-page">
    <section class="u-stack u-stack--lg">
      <header class="c-card p-6 md:p-8 bg-slate-50 border border-slate-200">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="u-stack u-stack--xs">
            <p class="c-eyebrow">Exports</p>
            <h1 class="c-page-title c-page-title--brand">Portfolio Export</h1>
            <p class="c-page-subtitle">Download student Google Sites portfolio URLs with student and advisor details.</p>
          </div>

          <div class="flex flex-wrap gap-2">
            <%= link_to "Reports Excel", export_reports_excel_path, class: tailwind_button_classes(:secondary), data: { turbo: false } %>
            <%= link_to "Student Records Excel", export_student_records_excel_path, class: tailwind_button_classes(:secondary), data: { turbo: false } %>
            <%= link_to "Download Excel",
                        download_student_portfolio_export_path(request.query_parameters),
                        class: tailwind_button_classes(:primary),
                        data: { turbo: false } %>
          </div>
        </div>
      </header>

      <section class="c-card p-6 md:p-8 u-stack u-stack--md">
        <div class="flex flex-wrap items-baseline justify-between gap-3">
          <div>
            <h2 class="c-section-title c-heading-inline">Filters</h2>
            <p class="text-sm text-slate-600">Refine the export before downloading.</p>
          </div>
          <%= link_to "Clear", student_portfolio_export_path, class: tailwind_button_classes(:secondary) %>
        </div>

        <%= form_with url: student_portfolio_export_path, method: :get, local: true, data: { turbo: false }, class: "c-toolbar__row c-toolbar__row--airy w-full md:flex-nowrap" do %>
          <div class="c-toolbar__item flex-1 min-w-[220px]">
            <label class="c-label" for="q">Search</label>
            <%= text_field_tag :q, params[:q], class: "c-input", placeholder: "Name, email, UIN" %>
          </div>
          <div class="c-toolbar__item md:w-56">
            <label class="c-label" for="track">Track</label>
            <%= select_tag :track, options_for_select([["All tracks", ""]] + ProgramTrack.names.map { |track| [track, track] }, params[:track]), class: "c-input" %>
          </div>
          <div class="c-toolbar__item md:w-40">
            <label class="c-label" for="program_year">Cohort</label>
            <%= number_field_tag :program_year, params[:program_year], class: "c-input" %>
          </div>
          <div class="c-toolbar__item flex items-end gap-2">
            <%= submit_tag "Apply", class: tailwind_button_classes(:primary) %>
          </div>
        <% end %>
      </section>

      <section class="c-card p-6 md:p-8 u-stack u-stack--md">
        <div class="flex flex-wrap items-baseline justify-between gap-3">
          <h2 class="c-section-title c-heading-inline">Students</h2>
          <span class="meta-chip"><%= pluralize(@rows.size, "student") %></span>
        </div>

        <div class="c-table-wrapper">
          <table class="c-table">
            <thead>
              <tr>
                <th>UIN</th>
                <th>Name</th>
                <th>Email</th>
                <th>Track</th>
                <th>Cohort</th>
                <th>Advisor</th>
                <th>Google Sites URL</th>
              </tr>
            </thead>
            <tbody>
              <% @rows.each do |row| %>
                <tr>
                  <td><%= row[:uin] %></td>
                  <td><%= row[:name] %></td>
                  <td><%= row[:email] %></td>
                  <td><%= row[:track] %></td>
                  <td><%= row[:program_year] %></td>
                  <td><%= row[:advisor] %></td>
                  <td class="break-all"><%= row[:portfolio_url].presence || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </section>
  </div>
</main>
