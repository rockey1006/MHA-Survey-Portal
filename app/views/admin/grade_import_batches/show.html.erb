<main class="main-content main-content--dashboard">
  <div class="c-toolbar">
    <div class="c-toolbar__row items-center w-full gap-3">
      <%= link_to "Back to batches", admin_grade_import_batches_path, class: tailwind_button_classes(:secondary) %>
    </div>
  </div>

  <div class="c-container c-container--wide c-page">
    <section class="c-card p-8 md:p-10 u-stack u-stack--xl">
      <header class="c-page-header">
        <div>
          <p class="c-eyebrow">Faculty imports</p>
          <h1 class="c-page-title c-page-title--brand">Grade Import Batch #<%= @batch.id %></h1>
          <p class="c-page-subtitle">
            <%= @batch.dry_run? ? "Preview batch" : "Committed batch" %>
            uploaded by <%= @batch.uploaded_by&.email || "unknown user" %>
            <% if @batch.program_semester.present? %>
              for <%= @batch.program_semester.name %>
            <% end %>
          </p>
        </div>

        <div class="u-actions">
          <% if @batch.committable_dry_run? %>
            <%= button_to "Commit preview", commit_admin_grade_import_batch_path(@batch), method: :post, class: tailwind_button_classes(:primary), form: { data: { turbo_confirm: "Publish this preview so its course competency ratings appear in the app?" } } %>
          <% end %>
          <% if @batch.recommittable_rollback? %>
            <%= button_to "Recommit batch", recommit_admin_grade_import_batch_path(@batch), method: :post, class: tailwind_button_classes(:primary), form: { data: { turbo_confirm: "Make this rolled-back batch visible in the app again?" } } %>
          <% end %>
          <%= link_to "Export CSV", export_ratings_admin_grade_import_batch_path(@batch, format: :csv), class: tailwind_button_classes(:secondary) %>
          <%= link_to "Error report", error_report_admin_grade_import_batch_path(@batch), class: tailwind_button_classes(:secondary) %>
          <% unless @batch.rolled_back? || @batch.dry_run? %>
            <%= button_to "Rollback batch", rollback_admin_grade_import_batch_path(@batch), method: :post, class: tailwind_button_classes(:danger), form: { data: { turbo_confirm: "Hide this committed batch from competencies, reports, and other downstream views?" } } %>
          <% end %>
          <%= button_to "Delete batch", admin_grade_import_batch_path(@batch), method: :delete, class: tailwind_button_classes(:danger), form: { data: { turbo_confirm: "Permanently delete this batch and all imported rows? This removes duplicate fingerprints so the same files can be uploaded again." } } %>
        </div>
      </header>

      <% if @batch.summary["rolled_back_at"].present? %>
        <div class="alert">
          Rolled back at <%= @batch.summary["rolled_back_at"] %>.
        </div>
      <% end %>

      <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-6">
        <div class="c-card c-card--tight c-stat">
          <span class="c-eyebrow">Status</span>
          <strong class="c-value c-value--xl"><%= @batch.status.humanize %></strong>
        </div>
        <div class="c-card c-card--tight c-stat">
          <span class="c-eyebrow">Processed Rows</span>
          <strong class="c-value c-value--xl"><%= @processed_row_count %></strong>
        </div>
        <div class="c-card c-card--tight c-stat">
          <span class="c-eyebrow">Failed Rows</span>
          <strong class="c-value c-value--xl"><%= @failed_row_count %></strong>
        </div>
        <div class="c-card c-card--tight c-stat">
          <span class="c-eyebrow">Pending Matches</span>
          <strong class="c-value c-value--xl"><%= @pending_row_count %></strong>
        </div>
        <div class="c-card c-card--tight c-stat">
          <span class="c-eyebrow">Match Rate</span>
          <strong class="c-value c-value--xl"><%= @match_rate ? "#{@match_rate}%" : "—" %></strong>
        </div>
        <div class="c-card c-card--tight c-stat">
          <span class="c-eyebrow">Derived Ratings</span>
          <strong class="c-value c-value--xl"><%= @batch.rating_count %></strong>
          <p class="c-help"><%= pluralize(@duplicate_warnings, "duplicate suppressed row") %></p>
        </div>
      </section>

      <details class="c-card c-card--flush c-section-group">
        <summary class="c-section-group__header">
          <h2>File Results</h2>
          <span><%= pluralize(@files.size, "file") %></span>
        </summary>
        <div class="c-table-wrapper">
          <table class="c-table">
            <thead>
              <tr>
                <th>File</th>
                <th>Status</th>
                <th>Rows</th>
                <th>Pending</th>
                <th>Matched</th>
                <th>Duplicates</th>
                <th>Errors</th>
              </tr>
            </thead>
            <tbody>
              <% @files.each do |file| %>
                <% debug = file.parsed_content["grade_sheet_debug"] || {} %>
                <tr>
                  <td class="c-table__title"><%= file.file_name %></td>
                  <td><%= file.status %></td>
                  <td><%= "#{file.imported_rows}/#{file.total_rows}" %></td>
                  <td><%= file.pending_rows %></td>
                  <td><%= debug["matched_student_count"] || "—" %></td>
                  <td><%= debug["duplicate_warning_count"] || 0 %></td>
                  <td>
                    <% if file.parse_errors.present? %>
                      <details class="c-cell-details">
                        <summary class="c-cell-details__summary"><%= pluralize(file.parse_errors.size, "issue") %></summary>
                        <ul class="mt-sm">
                          <% file.parse_errors.first(20).each do |err| %>
                            <li>Row <%= err["row"] || "—" %>: <%= err["message"] || err %></li>
                          <% end %>
                        </ul>
                      </details>
                    <% else %>
                      <span class="c-muted">None</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </details>

      <details class="c-card c-card--flush c-section-group">
        <summary class="c-section-group__header">
          <h2>Pending Student Matches</h2>
          <span><%= pluralize(@pending_rows.size, "row") %></span>
        </summary>
        <% pending_students = @pending_rows.map { |row| [row.student_name.presence || row.student_identifier.presence || "Unknown Student", row.student_uin.presence || "No UIN"] }.uniq %>
        <% if pending_students.empty? %>
          <div class="empty-state">
            <p class="empty-state__body">No pending student matches were created for this batch.</p>
          </div>
        <% else %>
          <div class="c-table-wrapper">
            <table class="c-table c-table--sm">
              <thead>
                <tr>
                  <th>Student</th>
                  <th>UIN</th>
                </tr>
              </thead>
              <tbody>
                <% pending_students.each do |student_label, student_uin| %>
                  <tr>
                    <td class="c-table__title"><%= student_label %></td>
                    <td><%= student_uin %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </details>

      <details class="c-card c-card--flush c-section-group">
        <summary class="c-section-group__header">
          <h2>Evidence Preview</h2>
          <span><%= pluralize(@evidences.size, "row") %></span>
        </summary>
        <% grouped_evidences = @evidences.group_by { |evidence| [evidence.student&.user&.name || "Unknown Student", evidence.student&.uin.presence || "No UIN"] } %>
        <% if grouped_evidences.empty? %>
          <div class="empty-state">
            <p class="empty-state__body">No evidence rows were created for this batch.</p>
          </div>
        <% else %>
          <div class="u-stack u-stack--sm p-4">
            <% grouped_evidences.each do |(student_name, student_uin), evidences| %>
              <details class="c-accordion">
                <summary class="c-accordion__summary">
                  <span class="c-accordion__title"><%= student_name %></span>
                  <span class="c-accordion__meta">UIN <%= student_uin %> · <%= pluralize(evidences.size, "grade row") %></span>
                </summary>
                <div class="c-table-wrapper">
                  <table class="c-table c-table--sm">
                    <thead>
                      <tr>
                        <th>Course</th>
                        <th>Assignment</th>
                        <th>Raw Grade</th>
                        <th>% of Assignment</th>
                        <th>Competency</th>
                        <th>Actual Level</th>
                        <th>Course Target</th>
                        <th>Source</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% evidences.each do |evidence| %>
                        <% points_possible = evidence.metadata["points_possible"] %>
                        <% percent_of_assignment = if points_possible.present? && points_possible.to_f.positive?
                          (evidence.raw_grade.to_f / points_possible.to_f) * 100.0
                        elsif evidence.metadata["score_basis"] == "percent"
                          evidence.metadata["score_for_mapping"].to_f
                        end %>
                        <tr>
                          <td><%= evidence.course_code.presence || "—" %></td>
                          <td><%= evidence.assignment_name %></td>
                          <td><%= evidence.raw_grade %></td>
                          <td><%= percent_of_assignment.present? ? "#{number_with_precision(percent_of_assignment, precision: 1, strip_insignificant_zeros: true)}%" : "—" %></td>
                          <td class="c-table__title"><%= evidence.competency_title %></td>
                          <td><span class="c-score-pill c-score-pill--course"><%= evidence.mapped_level %></span></td>
                          <td><span class="c-score-pill c-score-pill--program <%= 'c-score-pill--empty' if evidence.course_target_level.blank? %>"><%= evidence.course_target_level.presence || "—" %></span></td>
                          <td><%= evidence.grade_import_file&.file_name %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </details>
            <% end %>
          </div>
        <% end %>
      </details>

      <div class="u-actions u-actions--start">
        <%= link_to "Back to batches", admin_grade_import_batches_path, class: tailwind_button_classes(:secondary) %>
        <%= link_to "New batch", new_admin_grade_import_batch_path, class: tailwind_button_classes(:primary) %>
      </div>
    </section>
  </div>
</main>
