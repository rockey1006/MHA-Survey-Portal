<%= form_with url: url, method: :get, local: true, class: "flex w-full items-center gap-2" do %>
  <% hidden_params.to_h.each do |key, value| %>
    <% next if value.blank? %>
    <%= hidden_field_tag key, value %>
  <% end %>
  <%= label_tag param_name, "Search", class: "sr-only" %>
  <%= text_field_tag param_name,
                     query,
                     placeholder: placeholder,
                     class: "c-input c-search-input flex-1" %>
  <%= button_tag "Search", type: :submit, class: helpers.tailwind_button_classes(:secondary) %>
<% end %>
