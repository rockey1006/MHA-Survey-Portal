<nav class="c-card p-3" aria-label="Survey editor tabs">
  <div role="tablist" aria-label="Survey editor" class="flex flex-wrap gap-2">
    <button type="button"
            role="tab"
            id="tab-settings"
            class="<%= tailwind_button_classes(:primary, extra_classes: 'btn-sm') %>"
            data-survey-tabs-target="tab"
            data-tab-id="settings"
            data-action="survey-tabs#switchTab keydown->survey-tabs#handleKeydown"
            aria-selected="true"
            aria-controls="panel-settings"
            tabindex="0">
      General settings
    </button>

    <button type="button"
            role="tab"
            id="tab-builder"
            class="<%= tailwind_button_classes(:secondary, extra_classes: 'btn-sm') %>"
            data-survey-tabs-target="tab"
            data-tab-id="builder"
            data-action="survey-tabs#switchTab keydown->survey-tabs#handleKeydown"
            aria-selected="false"
            aria-controls="panel-builder"
            tabindex="-1">
      Question builder
    </button>

    <button type="button"
            role="tab"
            id="tab-legend"
            class="<%= tailwind_button_classes(:secondary, extra_classes: 'btn-sm') %>"
            data-survey-tabs-target="tab"
            data-tab-id="legend"
            data-action="survey-tabs#switchTab keydown->survey-tabs#handleKeydown"
            aria-selected="false"
            aria-controls="panel-legend"
            tabindex="-1">
      Legend
    </button>
  </div>
</nav>
