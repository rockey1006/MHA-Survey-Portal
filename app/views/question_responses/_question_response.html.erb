<div id="<%= dom_id question_response %>">
  <p>
    <strong>Student:</strong>
    <%= question_response.student&.full_name || question_response.student_id %>
  </p>

  <p>
    <strong>Advisor:</strong>
    <%= question_response.advisor&.display_name || question_response.advisor_id %>
  </p>

  <div>
    <strong>Question:</strong>
    <% if question_response.question.present? %>
      <div><%= render_question_prompt(question_response.question) %></div>
    <% else %>
      <%= question_response.question_id %>
    <% end %>
  </div>

  <p>
    <strong>Answer:</strong>
    <%= question_response.answer %>
  </p>

</div>
