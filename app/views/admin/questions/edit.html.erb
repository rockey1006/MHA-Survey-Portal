<main class="main-content">
  <section class="c-card p-8 md:p-10">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="c-section-title c-heading-inline">Edit Question</h1>
        <p class="mt-1 text-sm leading-relaxed text-slate-600">Update the prompt content, order, and tags.</p>
      </div>
      <div class="section-actions">
        <%= link_to "Back to Question Bank", admin_questions_path, class: tailwind_button_classes(:secondary) %>
      </div>
    </div>

    <%= render "form", question: @question %>
  </section>
</main>
